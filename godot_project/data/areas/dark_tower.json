      "lazarus_victory": {
        "actions": [
          {
            "action": "set_flag",
            "key": "lazarus_defeated"
          },
          {
            "action": "add_item",
            "item": "봉인 반지",
            "message": false
          },
          {
            "action": "print",
            "text": "\n라자러스가 무릎을 꿇는다.\n품에서 반짝이는 반지가 굴러 떨어진다.\n\n라자러스: \"...이런 결말이...\"\n\n▶ [봉인 반지] 획득! 왕의 봉인 반지. 모든 것의 시작이자 끝.\n▶ 어둠의 탑 공략 완료!\n"
          }
        ]
      }
    }
