              }
            ],
            "else": [
              {
                "action": "if",
                "cond": {
                  "equipped_weapon": "봉인의 검"
                },
                "then": [
                  {
                    "action": "print",
                    "text": "  ▶ 봉인의 검이 라자러스에게 반응하며 빛난다! (추가 데미지)"
                  },
                  {
                    "action": "add_stat",
