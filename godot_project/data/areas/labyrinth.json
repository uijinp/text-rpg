        "actions": [
          {
            "action": "divider",
            "title": "미궁 1층 - 세 갈래 길"
          },
          {
            "action": "print",
            "text": "\n세 갈래 길이 나타난다.\n"
          },
          {
            "action": "menu",
            "options": [
              {
                "label": "왼쪽 통로 (어둡고 좁다)",
