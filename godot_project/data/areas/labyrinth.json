                  {
                    "action": "random",
                    "branches": [
                      {
                        "weight": 0.4,
                        "actions": [
                          {
                            "action": "damage",
                            "amount": 25,
                            "message": false
                          },
                          {
                            "action": "print",
                            "text": "  함정 발동! 천장에서 돌이 떨어진다! (-25 HP)"
                          }
                        ]
                      },
                      {
                        "weight": 0.6,
                        "actions": [
                          {
                            "action": "add_gold",
                            "amount": 50,
                            "message": false
                          },
                          {
                            "action": "print",
                            "text": "  좁은 통로 끝에 숨겨진 보물함이 있다! (+50G)"
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "label": "중앙 통로 (정면에 빛이 보인다)",
                "actions": [
                  {
                    "action": "print",
                    "text": "\n  중앙 통로에서 미궁 수호자가 나타난다!"
                  },
                  {
                    "action": "battle",
                    "enemy": "labyrinth_guardian"
                  }
                ]
              },
              {
                "label": "오른쪽 통로 (바닥에 금화가 흩어져 있다)",
                "actions": [
                  {
                    "action": "add_item",
                    "item": "대형 포션",
                    "message": false
