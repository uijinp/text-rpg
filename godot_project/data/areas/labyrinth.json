                  {
                    "action": "add_gold",
                    "amount": 30,
                    "message": false
                  },
                  {
                    "action": "print",
                    "text": "  보물함에서 대형 포션과 금화를 발견했다! (+대형 포션, +30G)"
                  }
                ]
              }
            ]
          }
        ]
