            "else": [
              {
                "action": "menu",
                "options": [
                  {
                    "label": "'진실'",
                    "actions": [
                      {
                        "action": "print",
                        "text": "  정답! 석판이 빛나며 문이 열린다."
                      }
                    ]
                  },
                  {
                    "label": "'힘'",
                    "actions": [
                      {
                        "action": "damage",
                        "amount": 30,
                        "message": false
                      },
                      {
                        "action": "print",
                        "text": "  오답! 함정이 발동한다! (-30 HP)"
                      },
                      {
                        "action": "print",
                        "text": "  ...그래도 문은 천천히 열렸다."
                      }
                    ]
                  },
                  {
                    "label": "'용기'",
                    "actions": [
                      {
                        "action": "damage",
                        "amount": 30,
                        "message": false
                      },
                      {
                        "action": "print",
                        "text": "  오답! 함정이 발동한다! (-30 HP)"
                      },
                      {
                        "action": "print",
                        "text": "  ...그래도 문은 천천히 열렸다."
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      "cursed_chest": {
        "actions": [
          {
            "action": "divider",
            "title": "저주의 보물함"
          },
          {
            "action": "print",
            "text": "\n구석에 검은 기운이 감도는 보물함이 있다.\n강한 힘의 기운이 느껴진다... 하지만 불길하다.\n"
          },
          {
            "action": "menu",
            "options": [
              {
                "label": "연다 (강한 힘을 얻지만 대가가 있을 수 있다)",
