; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="어둠의 마왕을 물리쳐라!"
config/description="16비트 스타일 텍스트 RPG"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.3", "Mobile")
config/icon="res://icon.svg"

[autoload]

GameData="*res://scripts/autoload/game_data.gd"
GameState="*res://scripts/autoload/game_state.gd"
EventEngine="*res://scripts/autoload/event_engine.gd"
CombatSystem="*res://scripts/autoload/combat_system.gd"
AchievementMgr="*res://scripts/autoload/achievement_manager.gd"
StoryletMgr="*res://scripts/autoload/storylet_manager.gd"
SkillTreeMgr="*res://scripts/autoload/skill_tree_manager.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=854
window/size/mode=0
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

[gui]

theme/custom="res://themes/dark_fantasy.tres"
theme/custom_font="res://assets/fonts/default_font.tres"

[input]

move_up={
